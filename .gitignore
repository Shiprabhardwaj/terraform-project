# Local .terraform directory (contains binaries/modules)
.terraform/

# State files (contains sensitive infrastructure data)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (often contain secrets)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf

# Include override files you DO want to track (optional)
# !example_override.tf

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ingore directories
three-tier-aws/

# Ignore all terraform state files in any subdirectory
**/*.tfstate
**/*.tfstate.*
